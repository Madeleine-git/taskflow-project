{
  "name": "taskflow-project",
  "version": "1.0.0",
  "description": "Biblioteca Digital con Tailwind CSS",

  "scripts": {
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css && echo 'Build complete'",
    "watch": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}